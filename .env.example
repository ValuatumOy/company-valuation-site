# --- Stripe ---
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Public base URL used for Stripe success/cancel redirects
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Pricing (in EUR cents) ---
PRICE_EXISTING_REPORT=1000        # 10.00 EUR - we already hold the financials
PRICE_IMPORT_REPORT=1500          # 15.00 EUR - user imports 5y statements
PRICE_SHARE_DISCOUNT=200          # 2.00 EUR off if user lets us reuse their data

# --- Company data API (Valuatum backend) ---
# Leave empty to use the bundled mock dataset in src/lib/companies.ts
VALUATUM_DATA_API_URL=
VALUATUM_DATA_API_KEY=
